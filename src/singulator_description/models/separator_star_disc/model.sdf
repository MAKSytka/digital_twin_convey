<?xml version="1.0"?>
<sdf version="1.10">
  <model name="separator_star_disc">
    <static>false</static>
    <self_collide>false</self_collide>
    <link name="base">
      <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.01</iyy><iyz>0</iyz><izz>0.01</izz></inertia></inertial>
    </link>
    <link name="rotor">
      <inertial>
        <pose>0 0 0.055 0 0 0</pose>
        <mass>0.25</mass>
        <inertia><ixx>0.00009</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.00008</iyy><iyz>0</iyz><izz>0.00009</izz></inertia>
      </inertial>
      <collision name="disc_collision">
        <pose>0 0 0.055 1.570796327 0 0</pose>
        <max_contacts>6</max_contacts>
        <geometry><cylinder><radius>0.025</radius><length>0.030</length></cylinder></geometry>
        <surface><friction><ode><mu>1.10</mu><mu2>0.85</mu2><fdir1>1 0 0</fdir1></ode></friction></surface>
      </collision>
      <visual name="hub">
        <pose>0 0 0.055 1.570796327 0 0</pose>
        <geometry><cylinder><radius>0.019</radius><length>0.030</length></cylinder></geometry>
        <material><ambient>0.08 0.08 0.10 1</ambient><diffuse>0.14 0.14 0.17 1</diffuse><specular>0.35 0.35 0.35 1</specular></material>
      </visual>
      <visual name="tooth_a">
        <pose>0 0 0.055 0 0 0</pose>
        <geometry><box><size>0.064 0.030 0.012</size></box></geometry>
        <material><ambient>0.08 0.08 0.10 1</ambient><diffuse>0.14 0.14 0.17 1</diffuse><specular>0.35 0.35 0.35 1</specular></material>
      </visual>
      <visual name="tooth_b">
        <pose>0 0 0.055 0 1.570796327 0</pose>
        <geometry><box><size>0.064 0.030 0.012</size></box></geometry>
        <material><ambient>0.08 0.08 0.10 1</ambient><diffuse>0.14 0.14 0.17 1</diffuse><specular>0.35 0.35 0.35 1</specular></material>
      </visual>
    </link>
    <joint name="world_fixed" type="fixed"><parent>world</parent><child>base</child></joint>
    <joint name="shaft_joint" type="revolute">
      <parent>base</parent><child>rotor</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper><effort>80</effort><velocity>120</velocity></limit>
        <dynamics><damping>0.01</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>shaft_joint</joint_name>
      <topic>/singulator/separator/screen/cmd_vel</topic>
      <initial_velocity>80.0</initial_velocity>
    </plugin>
  </model>
</sdf>
