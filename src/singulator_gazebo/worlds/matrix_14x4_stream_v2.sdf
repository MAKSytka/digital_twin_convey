<?xml version="1.0"?>
<sdf version="1.10">
  <world name="matrix_14x4_stream">
    <gravity>0 0 -9.81</gravity>
    <physics name="physics_1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <light type="directional" name="sun">
      <pose>0 0 6 0 0 0</pose><cast_shadows>false</cast_shadows>
      <diffuse>0.9 0.9 0.9 1</diffuse><specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.2 -1.0</direction>
    </light>
    <model name="platform">
      <static>true</static>
      <pose>0.595000 0 -0.025 0 0 0</pose>
      <link name="platform_link">
        <collision name="platform_collision"><geometry><box><size>11.050000 1.160000 0.05</size></box></geometry></collision>
        <visual name="platform_visual"><geometry><box><size>11.050000 1.160000 0.05</size></box></geometry>
          <material><ambient>0.20 0.20 0.20 1</ambient><diffuse>0.30 0.30 0.30 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="infeed_conveyor">
      <static>true</static>
      <pose>-4.030000 0.000000 0 0 0 0</pose>
      <link name="belt">
        <pose>0 0 0.040000 0 0 0</pose>
        <collision name="belt_collision">
          <max_contacts>8</max_contacts>
          <geometry><box><size>1.200000 0.760000 0.080000</size></box></geometry>
          <surface><friction><ode>
            <mu>0.8</mu><mu2>0.8</mu2><fdir1>1 0 0</fdir1>
          </ode></friction></surface>
        </collision>
        <visual name="belt_visual">
          <geometry><box><size>1.200000 0.760000 0.080000</size></box></geometry>
          <material>
            <ambient>0.180 0.180 0.180 1</ambient>
            <diffuse>0.180 0.180 0.180 1</diffuse>
          </material>
        </visual>
      </link>

      <plugin filename="gz-sim-track-controller-system"
              name="gz::sim::systems::TrackController">
        <link>belt</link>
        <track_orientation>0 0 0</track_orientation>
        <velocity_topic>/singulator/infeed/cmd_vel</velocity_topic>
        <odometry_topic>/singulator/infeed/odometry</odometry_topic>
        <odometry_publish_frequency>1</odometry_publish_frequency>
        <min_velocity>-3.0</min_velocity>
        <max_velocity>3.0</max_velocity>
        <min_acceleration>-6.0</min_acceleration>
        <max_acceleration>6.0</max_acceleration>
        <min_jerk>-30.0</min_jerk>
        <max_jerk>30.0</max_jerk>
        <max_command_age>2.0</max_command_age>
      </plugin>

    </model>


